{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    extends: ["config:recommended", ":dependencyDashboard", ":semanticCommits"],

    // Both upstreams release fast (hermes-webui ships multiple times per day).
    // Batch into one weekly PR per upstream — see README.md "Upstream tracking".
    schedule: ["after 8am and before 9am on friday"],
    timezone: "UTC",
    prHourlyLimit: 0,
    prConcurrentLimit: 5,

    // hermes-agent: tracked via pyproject.toml git URL (pep621 manager handles it natively).
    // hermes-webui: tracked via Dockerfile ARG (custom regex manager below).
    customManagers: [
        {
            customType: "regex",
            description: "Track HERMES_WEBUI_VERSION in Dockerfile as a github-tags datasource",
            fileMatch: ["(^|/)Dockerfile$"],
            matchStrings: [
                "ARG HERMES_WEBUI_VERSION=(?<currentValue>v[\\d.]+)",
            ],
            depNameTemplate: "nesquena/hermes-webui",
            datasourceTemplate: "github-tags",
        },
        // One regex manager per pinned binary in scripts/pinned-binaries.tsv.
        // Each row uses tab-separated fields: name<TAB>version<TAB>url_amd64<TAB>...
        // When bumping, also update the two SHA256s in the same row.
        {
            customType: "regex",
            description: "yq pinned binary (scripts/pinned-binaries.tsv)",
            fileMatch: ["(^|/)scripts/pinned-binaries\\.tsv$"],
            matchStrings: ["^yq\\t(?<currentValue>v[\\d.]+)\\t"],
            depNameTemplate: "mikefarah/yq",
            datasourceTemplate: "github-releases",
        },
        {
            customType: "regex",
            description: "himalaya pinned binary (scripts/pinned-binaries.tsv)",
            fileMatch: ["(^|/)scripts/pinned-binaries\\.tsv$"],
            matchStrings: ["^himalaya\\t(?<currentValue>v[\\d.]+)\\t"],
            depNameTemplate: "pimalaya/himalaya",
            datasourceTemplate: "github-releases",
        },
        {
            customType: "regex",
            description: "pandoc pinned binary (scripts/pinned-binaries.tsv)",
            fileMatch: ["(^|/)scripts/pinned-binaries\\.tsv$"],
            matchStrings: ["^pandoc\\t(?<currentValue>[\\d.]+)\\t"],
            depNameTemplate: "jgm/pandoc",
            datasourceTemplate: "github-releases",
        },
        {
            customType: "regex",
            description: "typst pinned binary (scripts/pinned-binaries.tsv)",
            fileMatch: ["(^|/)scripts/pinned-binaries\\.tsv$"],
            matchStrings: ["^typst\\t(?<currentValue>v[\\d.]+)\\t"],
            depNameTemplate: "typst/typst",
            datasourceTemplate: "github-releases",
        },
        {
            customType: "regex",
            description: "tirith pinned binary (scripts/pinned-binaries.tsv)",
            fileMatch: ["(^|/)scripts/pinned-binaries\\.tsv$"],
            matchStrings: ["^tirith\\t(?<currentValue>v[\\d.]+)\\t"],
            depNameTemplate: "sheeki03/tirith",
            datasourceTemplate: "github-releases",
        },
    ],

    packageRules: [
        {
            description: "Group hermes-agent bumps — manual merge required (public repo, supply chain caution)",
            matchPackageNames: ["hermes-agent"],
            groupName: "hermes-agent",
            commitMessagePrefix: "chore(deps):",
            automerge: false,
        },
        {
            description: "Group hermes-webui bumps — manual merge required (public repo, supply chain caution)",
            matchPackageNames: ["nesquena/hermes-webui"],
            groupName: "hermes-webui",
            commitMessagePrefix: "chore(deps):",
            automerge: false,
        },
        {
            description: "Group all other deps together; require manual merge",
            matchPackageNames: ["*"],
            excludePackageNames: ["hermes-agent", "nesquena/hermes-webui"],
            groupName: "tooling",
            automerge: false,
        },
    ],
}
